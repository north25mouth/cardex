# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# NextAuth（npm run dev が 3001 など別ポートなら、そのURLに合わせる）
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # openssl rand -base64 32 で生成
# OAuthCallback が消えないときの切り分け（通常はコメントのまま）
# NEXTAUTH_DISABLE_PKCE=1

# Google OAuth（console.cloud.google.com で取得）
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxx

# Supabase（supabase.com のプロジェクト設定から取得）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxx

# Next.js dev watcher（EMFILE対策）
WATCHPACK_POLLING=true
WATCHPACK_POLLING_INTERVAL=1000
